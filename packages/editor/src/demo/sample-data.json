{
  "root": { "props": {} },
  "content": [
    {
      "type": "Box",
      "props": {
        "id": "page",
        "style": {
          "maxWidth": "1048px",
          "margin": "0 auto",
          "padding": "2rem",
          "fontFamily": "'Helvetica Neue', Helvetica, Arial, sans-serif",
          "color": "#111111"
        },
        "children": [
          {
            "type": "Stack",
            "props": {
              "id": "hero",
              "direction": "vertical",
              "gap": "1.5rem",
              "style": {
                "padding": "4rem 0 3rem",
                "textAlign": "center",
                "alignItems": "center"
              },
              "children": [
                {
                  "type": "Heading",
                  "props": {
                    "id": "hero-heading",
                    "level": "h1",
                    "text": "The editor is the canvas.",
                    "style": {
                      "fontSize": "3rem",
                      "fontFamily": "'Playfair Display', Georgia, serif"
                    }
                  }
                },
                {
                  "type": "Text",
                  "props": {
                    "id": "hero-description",
                    "text": "Duck brings AI composition and human review onto the same surface. No panels. No iframes. Just the page.",
                    "style": {
                      "fontSize": "1.25rem",
                      "color": "#555555",
                      "maxWidth": "600px",
                      "lineHeight": "1.6"
                    }
                  }
                },
                {
                  "type": "Stack",
                  "props": {
                    "id": "hero-actions",
                    "direction": "horizontal",
                    "gap": "0.75rem",
                    "style": {},
                    "children": [
                      {
                        "type": "Button",
                        "props": {
                          "id": "hero-cta-primary",
                          "label": "Start building",
                          "variant": "primary"
                        }
                      },
                      {
                        "type": "Button",
                        "props": {
                          "id": "hero-cta-secondary",
                          "label": "Read the docs",
                          "variant": "secondary"
                        }
                      }
                    ]
                  }
                }
              ]
            }
          },
          {
            "type": "Stack",
            "props": {
              "id": "features",
              "direction": "vertical",
              "gap": "2rem",
              "style": {
                "padding": "3rem 0"
              },
              "children": [
                {
                  "type": "Heading",
                  "props": {
                    "id": "features-heading",
                    "level": "h2",
                    "text": "What makes it different",
                    "style": {
                      "textAlign": "center",
                      "fontFamily": "'Playfair Display', Georgia, serif",
                      "fontSize": "1.875rem"
                    }
                  }
                },
                {
                  "type": "Grid",
                  "props": {
                    "id": "features-grid",
                    "columns": 3,
                    "gap": "1.5rem",
                    "children": [
                      {
                        "type": "Card",
                        "props": {
                          "id": "feature-1",
                          "style": {},
                          "children": [
                            {
                              "type": "Heading",
                              "props": {
                                "id": "feature-1-title",
                                "level": "h3",
                                "text": "Zero Chrome",
                                "style": {}
                              }
                            },
                            {
                              "type": "Text",
                              "props": {
                                "id": "feature-1-desc",
                                "text": "No panels, no toolbars. The rendered page is the editor. Everything is contextual — appears on interaction, disappears when done.",
                                "style": { "color": "#555555" }
                              }
                            }
                          ]
                        }
                      },
                      {
                        "type": "Card",
                        "props": {
                          "id": "feature-2",
                          "style": {},
                          "children": [
                            {
                              "type": "Heading",
                              "props": {
                                "id": "feature-2-title",
                                "level": "h3",
                                "text": "MCP-Native",
                                "style": {}
                              }
                            },
                            {
                              "type": "Text",
                              "props": {
                                "id": "feature-2-desc",
                                "text": "AI agents connect via MCP and compose UIs. The editor is a review surface, not a creation tool. Designers steer, AI builds.",
                                "style": { "color": "#555555" }
                              }
                            }
                          ]
                        }
                      },
                      {
                        "type": "Card",
                        "props": {
                          "id": "feature-3",
                          "style": {},
                          "children": [
                            {
                              "type": "Heading",
                              "props": {
                                "id": "feature-3-title",
                                "level": "h3",
                                "text": "Catalog-Agnostic",
                                "style": {}
                              }
                            },
                            {
                              "type": "Text",
                              "props": {
                                "id": "feature-3-desc",
                                "text": "Bring your own Puck Config — Primer, shadcn, Radix, or plain HTML. Drop in as-is, no migration needed.",
                                "style": { "color": "#555555" }
                              }
                            }
                          ]
                        }
                      }
                    ]
                  }
                }
              ]
            }
          },
          {
            "type": "Stack",
            "props": {
              "id": "cta",
              "direction": "vertical",
              "gap": "1rem",
              "style": {
                "padding": "3rem 0 4rem",
                "textAlign": "center",
                "alignItems": "center"
              },
              "children": [
                {
                  "type": "Heading",
                  "props": {
                    "id": "cta-heading",
                    "level": "h2",
                    "text": "Ready to build?",
                    "style": {
                      "fontFamily": "'Playfair Display', Georgia, serif",
                      "fontSize": "1.875rem"
                    }
                  }
                },
                {
                  "type": "Text",
                  "props": {
                    "id": "cta-desc",
                    "text": "npm install @duck/editor",
                    "style": {
                      "color": "#888888",
                      "fontFamily": "'Courier New', 'Lucida Console', monospace",
                      "fontSize": "0.875rem"
                    }
                  }
                },
                {
                  "type": "Button",
                  "props": {
                    "id": "cta-button",
                    "label": "Get started",
                    "variant": "primary"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
